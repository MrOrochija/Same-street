  lines:
  - speakerName: Player
    speakerSprite: {fileID: -6535718206531406139, guid: 06fdfd053eca4b54db118ee618099550, type: 3}
    text: "\u041F\u0440\u0438\u0432\u0435\u0442"
    narration: 0
  - speakerName: "\u043D\u043D \u0447\u0435\u043B"
    speakerSprite: {fileID: -4639100050811386979, guid: 3e596e96da7164847be0fe16c361479e, type: 3}
    text: "\u041F\u0440\u0438\u0432\u0435\u0442, \u043A\u0430\u043A \u0434\u0435\u043B\u0430?"
    narration: 0
  - speakerName: Player
    speakerSprite: {fileID: -6535718206531406139, guid: 06fdfd053eca4b54db118ee618099550, type: 3}
    text: "\u0423 \u043C\u0435\u043D\u044F \u0432\u0441\u0451 \u043E\u0442\u043B\u0438\u0447\u043D\u043E,
      \u0430 \u0443 \u0442\u0435\u0431\u044F \u043A\u0430\u043A?"
    narration: 0
  - speakerName: "\u043D\u043D \u0447\u0435\u043B"
    speakerSprite: {fileID: -4639100050811386979, guid: 3e596e96da7164847be0fe16c361479e, type: 3}
    text: "\u0423 \u043C\u0435\u043D\u044F \u0442\u043E\u0436\u0435 \u0432\u0441\u0451
      \u043E\u0442\u043B\u0438\u0447\u043D\u043E"
    narration: 0
